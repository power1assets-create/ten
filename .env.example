# .env.example — คัดลอกไฟล์นี้เป็น .env
# cp .env.example .env

PORT=3000

# ─── วิธีที่ 1: Railway / Cloud (ใช้ URL เดียว) ───────────────────────────────
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ─── วิธีที่ 2: Local PostgreSQL (แยก field) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crmdb
DB_USER=postgres
DB_PASSWORD=yourpassword
